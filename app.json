{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "platforms": ["android", "ios", "web"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.lingjing-media.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "需要访问相册以选择图片生成AI内容",
        "NSCameraUsageDescription": "需要相机拍摄照片用于AI生成",
        "NSMicrophoneUsageDescription": "需要麦克风录制音频用于数字人功能"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lingjing_media.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "static": [
      {
        "source": "privacy.html",
        "target": "privacy.html"
      },
      {
        "source": "terms.html",
        "target": "terms.html"
      }
    ],
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "65cc5eeb-d2cd-4970-8b9d-30bb3848528f"
      }
    }
  }
}